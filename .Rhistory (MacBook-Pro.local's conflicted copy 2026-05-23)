search_error_message <- function(pkg_path = ".", message = "Error occurred:  not enough finite observations") {
# Get a list of all R script files in the package
r_files <- list.files(file.path(pkg_path, "R"), pattern = "\\.R$", recursive = TRUE, full.names = TRUE)
# Search for the message in each file
matches <- lapply(r_files, function(file) {
lines <- readLines(file, warn = FALSE)
matching_lines <- grep(message, lines, value = TRUE)
if (length(matching_lines) > 0) {
return(data.frame(File = file, LineNumber = grep(message, lines), Code = matching_lines, stringsAsFactors = FALSE))
} else {
return(NULL)
}
})
# Combine results into a single dataframe
results <- do.call(rbind, matches)
if (!is.null(results)) {
print(results)
} else {
message("No occurrences of the error message were found in your package source code.")
}
}
