# Fix covariate p-values
#' @title Make a Group Comparison Table with Covariate Adjustment and Pairwise Contrasts
#'
#' @description
#' Creates a summary comparison table using {gtsummary}, with automatic selection of
#' unadjusted and covariate-adjusted p-values, optional effect sizes, and pairwise contrasts.
#'
#' @param DataFrame A data.frame of raw data.
#' @param Variables Character vector of variable names to include.
#' @param CompVariable Character string: grouping variable name.
#' @param Covariates Character vector of covariates for adjustment. Default NULL.
#' @param ValueDigits Digits for summary stats. Default 2.
#' @param pDigits Digits for p-values. Default 3.
#' @param AddEffectSize Logical: include effect-size column. Default FALSE.
#' @param EffectSizeDigits Digits for effect sizes. Default 2.
#' @param AddPairwise Logical: include pairwise contrasts. Default FALSE.
#' @param PairwiseMethod Method for pairwise p-value adjustment. Default "bonferroni".
#' @param suppress_warnings Logical: suppress warnings. Default FALSE.
#'
#' @return A gtsummary table object with adjusted p-values, effect sizes, and contrasts.
#' @export
MakeComparisonTable <- function(
DataFrame,
Variables,
CompVariable,
Covariates = NULL,
ValueDigits = 2,
pDigits = 3,
AddEffectSize = FALSE,
EffectSizeDigits = 2,
AddPairwise = FALSE,
PairwiseMethod = "bonferroni",
suppress_warnings = FALSE
) {
# Load required packages
pkgs <- c("gtsummary","dplyr","car","emmeans","broom","effectsize","purrr","tidyr")
missing <- pkgs[!vapply(pkgs, requireNamespace, logical(1), quietly=TRUE)]
if(length(missing)) stop("Install: ", paste(missing, collapse=","))
# Prepare data
df <- DataFrame %>%
dplyr::select(any_of(c(CompVariable, Variables, Covariates))) %>%
dplyr::select_if(~ !(is.factor(.) && nlevels(.)>15))
df[[CompVariable]] <- factor(df[[CompVariable]])
# Build base summary (only main Variables, not covariates)
df_table <- df %>% dplyr::select(any_of(c(CompVariable, Variables)))
tbl <- gtsummary::tbl_summary(
df_table,
by = CompVariable,
statistic = list(
all_continuous() ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p})"
),
digits = list(all_continuous() ~ ValueDigits)
) %>%
gtsummary::add_n()
if(suppress_warnings) tbl <- suppressWarnings(tbl)
# Compute p-values manually
pvals <- purrr::map_dfr(Variables, function(var) {
# unadjusted
if(is.numeric(df[[var]])) {
m0 <- stats::aov(as.formula(paste(var,"~",CompVariable)), df)
pu <- summary(m0)[[1]][CompVariable,"Pr(>F)"]
} else {
tbl0 <- table(df[[var]], df[[CompVariable]])
pu <- if(any(suppressWarnings(stats::chisq.test(tbl0)$expected)<5)) stats::fisher.test(tbl0)$p.value
else stats::chisq.test(tbl0)$p.value
}
# adjusted
if(!is.null(Covariates)) {
f_adj <- paste(var,"~",CompVariable,"+",paste(Covariates,collapse="+"))
if(is.numeric(df[[var]])) {
m1 <- stats::lm(as.formula(f_adj), df)
pad <- car::Anova(m1,type=2)[CompVariable,"Pr(>F)"]
} else {
tbl0 <- table(df[[var]], df[[CompVariable]])
pad <- stats::chisq.test(tbl0)$p.value
}
} else pad <- NA_real_
tibble::tibble(variable=var, p_unadj=pu, p_adj=pad)
})
# Join p-values
tbl <- tbl %>%
gtsummary::modify_table_body(~ .x %>%
left_join(pvals,by="variable") %>%
mutate(
p.value = coalesce(p_adj,p_unadj),
p.value_fmt = gtsummary::style_pvalue(p.value,digits=pDigits)
)
) %>%
gtsummary::modify_table_styling(
columns="p.value_fmt",
rows=.data$p.value<=0.05,
text_format="bold"
) %>%
gtsummary::modify_header(p.value_fmt~"**p-value**") %>%
gtsummary::modify_footnote(
p.value_fmt~if(!is.null(Covariates)) paste0("Adjusted for: ",paste(Covariates,collapse=","))
else "Unadjusted"
)
# Effect sizes
if(AddEffectSize) {
es_df <- purrr::map_dfr(Variables, function(var) {
if(is.numeric(df[[var]])) {
m0 <- stats::aov(as.formula(paste(var,"~",CompVariable)),df)
eta_tbl <- effectsize::eta_squared(m0, partial = !is.null(Covariates))
es <- as.numeric(eta_tbl$Eta2_partial[1])
} else {
tbl0 <- table(df[[var]],df[[CompVariable]])
chi2 <- suppressWarnings(stats::chisq.test(tbl0))$statistic
n <- sum(tbl0); k <- min(nrow(tbl0)-1,ncol(tbl0)-1)
es <- sqrt(as.numeric(chi2)/(n*k))
}
tibble::tibble(variable=var, effect_size=round(es,EffectSizeDigits))
})
tbl <- tbl %>%
gtsummary::modify_table_body(~ .x %>% left_join(es_df,by="variable")) %>%
gtsummary::modify_fmt_fun(
effect_size ~ function(x) formatC(x, digits = EffectSizeDigits, format = "f")
) %>%
gtsummary::modify_header(effect_size~"**Effect Size**") %>%
gtsummary::modify_footnote(
effect_size~ if(!is.null(Covariates)) "Partial η² (adjusted) or Cramer's V" else "η² or Cramer's V"
)
}
# Pairwise contrasts
if(AddPairwise && length(unique(df[[CompVariable]]))>2) {
pw <- purrr::map_dfr(Variables, function(var) {
if(!is.numeric(df[[var]])) return(NULL)
fit <- stats::aov(as.formula(paste(var,"~",CompVariable)),df)
em  <- emmeans::emmeans(fit,CompVariable)
ct  <- emmeans::contrast(em,method="pairwise",adjust=PairwiseMethod)
res <- broom::tidy(ct)
pcol<-intersect(c("p.value","p.value_adj","adj.p.value"),names(res))[1]
tibble::tibble(variable=var, contrast=res$contrast, p_val=res[[pcol]])
})
pw_wide <- tidyr::pivot_wider(pw,id_cols="variable",names_from="contrast",values_from="p_val")
tbl <- tbl %>%
gtsummary::modify_table_body(~ .x %>% left_join(pw_wide,by="variable"))
# format each pairwise column
pw_cols <- setdiff(names(pw_wide),"variable")
for(col in pw_cols) {
tbl <- tbl %>%
gtsummary::modify_fmt_fun(!!rlang::sym(col) ~ function(x) gtsummary::style_pvalue(x, digits = pDigits)) %>%
gtsummary::modify_table_styling(columns = col, rows = .data[[col]] <= 0.05, text_format = "bold") %>%
gtsummary::modify_header(!!rlang::sym(col) := paste0("**", col, " (", PairwiseMethod, ")**")) %>%
gtsummary::modify_footnote(!!rlang::sym(col) ~ paste0("Pairwise p-value adjusted by ", PairwiseMethod))
}
}
# Final caption and return and return
tbl %>% gtsummary::modify_caption("Comparison Table")
}
